[Unit]
Description=FlexDNS Local DNS Resolver
After=network-online.target
Wants=network-online.target

StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple

ExecStart=/usr/lib/flexdns

Restart=on-failure
RestartSec=2

StandardOutput=null
StandardError=null

LimitNOFILE=65536

User=root
NoNewPrivileges=true
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE

PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target