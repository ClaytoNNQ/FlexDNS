[Unit]
Description=FlexDNS Local DNS Resolver
After=network-online.target
Wants=network-online.target

StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple
ExecStart=/usr/lib/flexdns/flexDNS
User=root
AmbientCapabilities=CAP_NET_BIND_SERVICE
Restart=on-failure
RestartSec=2
LimitNOFILE=65536

NoNewPrivileges=false
ProtectSystem=off
ProtectHome=false
PrivateTmp=false

StandardOutput=null
StandardError=null

[Install]
WantedBy=multi-user.target